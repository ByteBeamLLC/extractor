# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter (LLM)
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=google/gemini-2.5-pro

# OCR (optional)
HUGGINGFACE_API_KEY=your-hf-key
HUGGINGFACE_DOTS_OCR_ENDPOINT=your-endpoint

# Gmail OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://parsli.co/api/auth/gmail/callback

# Cron
CRON_SECRET=your-cron-secret

# Email (Resend) — transactional notifications
RESEND_API_KEY=re_...
EMAIL_FROM="Parsli <noreply@parsli.co>"

# Web Push (VAPID) — Phase 2 push notifications
# Generate once with: npx web-push generate-vapid-keys
# The PUBLIC key MUST be exposed via NEXT_PUBLIC_ so the browser can subscribe.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@parsli.co

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_GROWTH_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_ANNUAL=price_...

# App
NEXT_PUBLIC_SITE_URL=https://parsli.co
NEXT_PUBLIC_APP_URL=https://app.parsli.co

# Analytics
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token
MIXPANEL_TOKEN=your-mixpanel-token
MIXPANEL_API_SECRET=your-mixpanel-api-secret

# OAuth State Signing (HMAC-SHA256 for Google OAuth state parameter)
STATE_SIGNING_SECRET=generate-a-random-64-char-hex-string

# QuickBooks Online integration
# Register an app at https://developer.intuit.com to get the client id/secret.
# QUICKBOOKS_ENV controls the API host: "sandbox" (default) hits the sandbox
# API, "production" hits real customer QBO companies. Flip to "production"
# only after Intuit's App Assessment approves your production keys.
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_ENV=sandbox
# AES-256 key for encrypting QBO refresh/access tokens at rest, per Intuit's
# security requirements. Generate ONCE with: openssl rand -hex 32
# This value MUST be identical across all environments that share a database
# (if dev and prod share a Supabase project, use the same key). Rotating this
# key requires a coordinated re-encryption of existing rows.
QUICKBOOKS_TOKEN_ENCRYPTION_KEY=

# Feature Flags
# Set to "false" to disable the handwriting-to-text bridge chat. Default: enabled.
# NEXT_PUBLIC_FEATURE_HWT_BRIDGE=true

# Error Reporting (GitHub Issues auto-creation)
GITHUB_ERROR_REPORT_TOKEN=ghp_... # Fine-grained PAT with issues:write scope
GITHUB_REPO=TalalBazerbachi/parsli
